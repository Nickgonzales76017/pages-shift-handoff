#!/usr/bin/env bash
# ─── Bonfyre Pages App Hook ──────────────────────────────────────────────────
set -euo pipefail

BONFYRE_BIN="${BONFYRE_BIN:-$HOME/.local/bin}"
export PATH="$BONFYRE_BIN:$PATH"

log() { printf "\033[0;33m[bonfyre]\033[0m %s\n" "$1"; }
err() { printf "\033[0;31m[bonfyre]\033[0m %s\n" "$1" >&2; }

require_bin() {
  for b in "$@"; do
    command -v "$b" >/dev/null 2>&1 || { err "Missing: $b (run 'make install' in bonfyre-oss)"; return 1; }
  done
}
log "Checking handoff board is current…"
URGENT=$(find artifacts/ -name '*.tone.json' -newer site/index.html 2>/dev/null | head -1)
if [ -n "$URGENT" ]; then
  err "Tone analysis newer than board — rebuild with 'make build'."
  exit 1
fi
log "Board is current."
